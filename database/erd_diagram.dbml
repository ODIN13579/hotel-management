Table Users {
  User_ID varchar [not null, pk, note: 'mã định danh duy nhất của người dùng']
  Name nvarchar [not null]
  Email varchar [unique, note: 'không trùng email']
  Phone varchar
}

Table Services {
  Service_ID varchar [not null, pk, note: 'mã định danh duy nhất của dịch vụ']
  Name nvarchar [not null]
  Description nvarchar 
  Price decimal(18,2)
}

Table Rooms {
  Room_ID varchar [pk, note: 'Mã định danh duy nhất của phòng']
  Room_Number varchar 
  Capacity integer 
  Price_Per_Night decimal(18,2)
  Status varchar [note: 'Trống, Đã đặt, Bảo trì']
}

Table Rooms_Services {
  Room_ID varchar [ref: > Rooms.Room_ID]
  Service_ID varchar [ref: > Services.Service_ID]
  primary key (Room_ID, Service_ID)
}

Table Employees {
  Employee_ID varchar [not null,pk]
  Name nvarchar 
  Email varchar [unique]
  Phone varchar 
  Role varchar 
  Status varchar 
}

Table Bookings {
  Booking_ID varchar [pk]
  User_ID varchar [ref: > Users.User_ID] 
  Room_ID varchar [ref: > Rooms.Room_ID] 
  Employee_ID varchar [ref: > Employees.Employee_ID]
  Date datetime 
  Check_In datetime 
  Check_Out datetime 
  Status varchar [note: 'Chờ xác nhận, Đã nhận phòng, Đã trả phòng, Đã hủy']
}

Table Reviews {
  Review_ID varchar [pk] 
  User_ID varchar [ref: > Users.User_ID]
  Booking_ID varchar [ref: > Bookings.Booking_ID] // thay vi đánh giá dịch vụ thì đánh giá trải nghiệm phòng
  Rating integer [note: '1-5 sao']
  Comment nvarchar 
}

Table Payment {
  Payment_ID varchar [pk]
  Booking_ID varchar [ref: > Bookings.Booking_ID]
  Amount decimal(18,2)
  Payment_Date datetime 
  Payment_Method varchar [note: 'Cash, Credit Card, Transfer']
}

Table CancellationRefund {
  CancellationRefund_ID varchar [pk]
  Booking_ID varchar [ref: - Bookings.Booking_ID] // 1-1
  Cancellation_Date datetime 
  Refund_Amount decimal(18,2)
}

Table Invoices {
  Invoice_ID  varchar [pk]
  User_ID varchar [ref: > Users.User_ID]
  Booking_ID varchar [ref: - Bookings.Booking_ID] // 1-1
  Amount decimal(18,2)
  Date datetime 
}

Table Notifications {
  Notification_ID  varchar [pk]
  User_ID varchar [ref: > Users.User_ID]
  Message nvarchar 
  Date datetime 
}